{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css,md,yml,yaml,html}\"",
    "format:write": "prettier --write \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css,md,yml,yaml,html}\"",
    "typos": "typos",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "knip": "knip --no-config-hints"
  },
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "firebase": "^12.14.0",
    "lucide-solid": "^0.475.0",
    "solid-js": "^1.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@ocular-d/typos-bin": "^1.47.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "knip": "^6.20.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.9"
  }
}
